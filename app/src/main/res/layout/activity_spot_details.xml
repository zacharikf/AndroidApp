<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F7FA">

    <ImageView
        android:id="@+id/detailIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_logo"
        android:layout_gravity="center"
        app:tint="#2E7D32"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/detailName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Όνομα Τοποθεσίας"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Περιγραφή:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#757575"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Αναλυτική περιγραφή του study spot..."
        android:textSize="18sp"
        android:textColor="#424242"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ακριβής Τοποθεσία:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#757575"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detailCoords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lat: 0.0, Lon: 0.0"
        android:textSize="16sp"
        android:textColor="#1976D2"
        android:textStyle="italic"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="ΕΠΙΣΤΡΟΦΗ ΣΤΗ ΛΙΣΤΑ"
        android:backgroundTint="#2E7D32"
        app:cornerRadius="12dp"/>

</LinearLayout>